# CoreMesh AI — Runtime Environment Variables
# Copy this file to .env and fill in your values before starting the service.

# ---------------------------------------------------------------------------
# OpenAI API (required for LLM extraction + vision fallback)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# Model selection
OPENAI_EXTRACTION_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# OCR settings
# ---------------------------------------------------------------------------

# Variance threshold (0.0–1.0): if tesseract/easyocr disagree more than this,
# the vision LLM fallback is invoked.  Default: 0.08 (8%)
OCR_VARIANCE_THRESHOLD=0.08

# Path to the Tesseract binary.  Leave empty to use the system PATH.
# Windows example: C:/Program Files/Tesseract-OCR/tesseract.exe
TESSERACT_CMD=

# Path to the Poppler bin/ directory (Windows only; leave empty on Linux/macOS).
# Windows example: C:/Program Files/poppler-24.02.0/Library/bin
POPPLER_PATH=

# ---------------------------------------------------------------------------
# Infrastructure
# ---------------------------------------------------------------------------
POSTGRES_DSN=postgresql://coremesh:coremesh_secret@localhost:5432/coremesh
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=coremesh_chunks
QDRANT_VECTOR_SIZE=1536
RERANKER_MODEL=BAAI/bge-reranker-large

# ---------------------------------------------------------------------------
# Hybrid retrieval tuning (RRF fusion + reranker)
# ---------------------------------------------------------------------------
# RRF weights applied to dense (vector) vs sparse (BM25) rank contributions.
# Equal weights (1.0 / 1.0) reproduce plain unweighted RRF. To bias toward
# semantic recall, e.g. use 0.7 / 0.3.
RAG_DENSE_WEIGHT=1.0
RAG_SPARSE_WEIGHT=1.0

# When true, exact technical-identifier matches (e.g. CircuitBreakerState.OPEN)
# are promoted ahead of the cross-encoder score as a deterministic tie-breaker.
# Set false to rank purely by the reranker.
RAG_KEYWORD_PRIORITY=true
