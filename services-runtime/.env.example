# CoreMesh AI — Runtime Environment Variables
# Copy this file to .env and fill in your values before starting the service.

# ---------------------------------------------------------------------------
# OpenAI API (required for LLM extraction + vision fallback)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# Model selection
OPENAI_EXTRACTION_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# OCR settings
# ---------------------------------------------------------------------------

# Variance threshold (0.0–1.0): if tesseract/easyocr disagree more than this,
# the vision LLM fallback is invoked.  Default: 0.08 (8%)
OCR_VARIANCE_THRESHOLD=0.08

# Path to the Tesseract binary.  Leave empty to use the system PATH.
# Windows example: C:/Program Files/Tesseract-OCR/tesseract.exe
TESSERACT_CMD=

# Path to the Poppler bin/ directory (Windows only; leave empty on Linux/macOS).
# Windows example: C:/Program Files/poppler-24.02.0/Library/bin
POPPLER_PATH=

# ---------------------------------------------------------------------------
# Infrastructure
# ---------------------------------------------------------------------------
POSTGRES_DSN=postgresql://coremesh:coremesh_secret@localhost:5432/coremesh
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
